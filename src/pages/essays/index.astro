---
import Basis from '../../layouts/Basis.astro';
import { getCollection } from 'astro:content';
import { ladeSubstackFeed } from '../../lib/substack';

type StromEintrag = {
  art: 'essay' | 'substack';
  title: string;
  datum: Date;
  url: string;
};

const essays = await getCollection('essays');
const substack = await ladeSubstackFeed();

const strom: StromEintrag[] = [
  ...essays.map((e) => ({
    art: 'essay' as const,
    title: e.data.title,
    datum: e.data.date,
    url: `/essays/${e.id}/`,
  })),
  ...substack.map((s) => ({
    art: 'substack' as const,
    title: s.title,
    datum: s.datum,
    url: s.url,
  })),
].sort((a, b) => b.datum.valueOf() - a.datum.valueOf());

const formatDatum = (datum: Date) =>
  datum.toLocaleDateString('de-DE', { day: '2-digit', month: 'long', year: 'numeric' });
---

<Basis titel="Essays — notitia">
  <h1>Essays</h1>
  <p class="intro">Ein Essay pro Monat. Philosophie aus dem Inneren der Verwaltung.</p>
  {strom.length === 0 ? (
    <p>Noch keine Essays.</p>
  ) : (
    <ul class="liste">
      {strom.map((eintrag, i) => {
        const extern = eintrag.art === 'substack';
        return (
          <li style={`animation-delay: ${Math.min(i, 10) * 60}ms`}>
            <a
              href={eintrag.url}
              {...(extern ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              <span class="titel">{eintrag.title}</span>
              <span class="meta">
                <span>{formatDatum(eintrag.datum)}</span>
                {extern && <span class="ort">· auf Substack ↗</span>}
              </span>
            </a>
          </li>
        );
      })}
    </ul>
  )}
</Basis>

<style>
  h1 {
    animation: aufklaren 0.6s ease-out both;
  }

  .intro {
    color: var(--grau);
    font-style: italic;
    margin: 0 0 2rem;
    animation: aufklaren 0.6s ease-out 100ms both;
  }

  .liste {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .liste li {
    padding: 1rem 0;
    border-bottom: 1px solid var(--linie);
    animation: einblenden 0.5s var(--feder) both;
  }

  .liste li:last-child {
    border-bottom: none;
  }

  .liste a {
    position: relative;
    text-decoration: none;
    color: var(--ink);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    transition: transform 0.35s var(--feder);
  }

  /* Beim Hover rutscht der Eintrag nach rechts, ein Pfeil taucht links auf */
  .liste a::before {
    content: '→';
    position: absolute;
    left: -1.5rem;
    top: 0.1rem;
    color: var(--akzent);
    opacity: 0;
    transform: translateX(-8px);
    transition: opacity 0.25s ease, transform 0.35s var(--feder);
  }

  .liste a:hover {
    transform: translateX(10px);
  }

  .liste a:hover::before {
    opacity: 1;
    transform: none;
  }

  .liste a:hover .titel {
    color: var(--akzent);
  }

  @media (max-width: 640px) {
    .liste a::before {
      display: none;
    }

    .liste a:hover {
      transform: none;
    }
  }

  .titel {
    font-size: 1.15rem;
    transition: color 0.15s ease;
  }

  .meta {
    font-family: var(--schrift-ui);
    font-size: 0.85rem;
    color: var(--grau);
  }

  .ort {
    margin-left: 0.4rem;
  }
</style>
