---
import Basis from '../../layouts/Basis.astro';
import { getCollection, render } from 'astro:content';
import felderDaten from '../../data/felder.json';

export async function getStaticPaths() {
  const essays = await getCollection('essays');
  return essays.map((essay) => ({
    params: { slug: essay.id },
    props: { essay },
  }));
}

const { essay } = Astro.props;
const { Content } = await render(essay);

const datum = essay.data.date.toLocaleDateString('de-DE', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});

const feld = felderDaten.felder.find((f) => f.slug === essay.data.feld);
---

<Basis titel={`${essay.data.title} — magnolia`}>
  <article>
    <header class="kopf">
      <p class="meta">
        {datum}
        {feld && (
          <>
            <span aria-hidden="true"> · </span>
            <a href={`/felder/${feld.slug}`}>{feld.name}</a>
          </>
        )}
      </p>
      <h1>{essay.data.title}</h1>
      {essay.data.deck && <p class="deck">{essay.data.deck}</p>}
    </header>
    {essay.data.bild && (
      <figure class="hero">
        <img src={`/bilder/${essay.data.bild}`} alt={essay.data.title} />
        {essay.data.bild_caption && (
          <figcaption set:html={essay.data.bild_caption} />
        )}
      </figure>
    )}
    <Content />
  </article>
</Basis>

<style>
  .kopf {
    margin-bottom: 2rem;
  }

  .meta {
    font-family: var(--schrift-ui);
    font-size: 0.85rem;
    color: var(--grau);
    margin: 0 0 0.5rem;
    letter-spacing: 0.02em;
  }

  .meta a {
    color: var(--grau);
    text-decoration: underline;
    text-decoration-color: var(--linie);
  }

  .meta a:hover {
    color: var(--ink);
  }

  article :global(p) {
    margin: 0 0 1rem;
  }

  article :global(blockquote) {
    border-left: 2px solid var(--akzent);
    margin: 1.5rem 0;
    padding: 0.25rem 0 0.25rem 1rem;
    color: var(--grau);
    font-style: italic;
  }

  article :global(em) {
    font-style: italic;
  }

  .deck {
    font-size: 1.15rem;
    font-style: italic;
    color: var(--grau);
    margin: 0.5rem 0 0;
    line-height: 1.4;
  }

  .hero {
    margin: 2rem 0;
  }

  .hero img {
    width: 100%;
    height: auto;
    display: block;
  }

  .hero figcaption {
    font-family: var(--schrift-ui);
    font-size: 0.8rem;
    color: var(--grau);
    margin-top: 0.5rem;
    line-height: 1.4;
  }

  .hero figcaption :global(a) {
    color: var(--grau);
    text-decoration: underline;
    text-decoration-color: var(--linie);
  }

  .hero figcaption :global(a:hover) {
    color: var(--ink);
  }
</style>
