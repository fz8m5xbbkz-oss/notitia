---
import Basis from '../../layouts/Basis.astro';
import { getCollection, render, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const essays = await getCollection('essays');
  return essays.map((essay) => ({
    params: { slug: essay.id },
    props: { essay },
  }));
}

const { essay } = Astro.props;
const { Content } = await render(essay);

const datum = essay.data.date.toLocaleDateString('de-DE', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});

const feldEntry = await getEntry('felder', essay.data.feld);
const feld = feldEntry ? { name: feldEntry.data.title } : null;
---

<Basis titel={`${essay.data.title} — notitia`} leserModus={true}>
  <article>
    <a href="/essays" class="zurueck">← Essays</a>
    <header class="kopf">
      <p class="meta">
        {datum}
        {feld && (
          <>
            <span aria-hidden="true"> · </span>
            <span>{feld.name}</span>
          </>
        )}
      </p>
      <h1>{essay.data.title}</h1>
    </header>
    <Content />
  </article>
</Basis>

<style>
  /* Nur im Reader Mode (mobile) sichtbar — Rücknavigation ohne globalen Header */
  .zurueck {
    display: none;
    font-family: var(--schrift-ui);
    font-size: 0.85rem;
    color: var(--grau);
    text-decoration: none;
    margin-bottom: 2rem;
  }

  @media (max-width: 640px) {
    .zurueck {
      display: block;
    }
  }

  .kopf {
    margin-bottom: 2rem;
  }

  .meta {
    font-family: var(--schrift-ui);
    font-size: 0.85rem;
    color: var(--grau);
    margin: 0 0 0.5rem;
    letter-spacing: 0.02em;
  }

  .meta a {
    color: var(--grau);
    text-decoration: underline;
    text-decoration-color: var(--linie);
  }

  .meta a:hover {
    color: var(--ink);
  }

  article :global(p) {
    margin: 0 0 1rem;
  }

  article :global(blockquote) {
    border-left: 2px solid var(--akzent);
    margin: 1.5rem 0;
    padding: 0.25rem 0 0.25rem 1rem;
    color: var(--grau);
    font-style: italic;
  }

  article :global(em) {
    font-style: italic;
  }
</style>
