---
import Basis from '../layouts/Basis.astro';
import Vignette from '../components/Vignette.astro';
import { aktuell, geplant, abgeschlossen, empfohlen } from '../data/lektuere.js';

// Anzeige-Reihenfolge der Sektionen; leere Listen fallen raus.
const sektionen = [
  { titel: 'Gerade', buecher: aktuell },
  { titel: 'Geplant', buecher: geplant },
  { titel: 'Abgeschlossen', buecher: abgeschlossen },
  { titel: 'Empfohlen', buecher: empfohlen },
].filter((s) => s.buecher.length > 0);
---

<Basis
  titel="Lektüre — annotanda"
  beschreibung="Was ich gerade lese, geplant und abgeschlossen habe — und was ich empfehle."
>
  <Vignette motiv="buecher" />
  <h1 data-reveal>Lektüre</h1>

  <p data-reveal style="--reveal-delay: 80ms">
    Ein laufendes Leseprotokoll.
  </p>

  {sektionen.map((sektion) => (
    <section>
      <h2 data-reveal>{sektion.titel}</h2>
      <ol>
        {sektion.buecher.map((b, i) => (
          <li data-reveal style={`--reveal-delay: ${Math.min(i, 6) * 70}ms`}>
            <span class="autor">{b.autor ? `${b.autor}: ` : ''}</span>{b.url
              ? <a href={b.url} target="_blank" rel="noopener noreferrer"><em>{b.titel}</em></a>
              : <em>{b.titel}</em>
            }{b.jahr && <span class="meta">, {b.jahr}</span>}
            {b.notiz && <p class="notiz">{b.notiz}</p>}
            {b.resuemee && (
              <a class="resuemee-link" href={`/buecher/${b.resuemee}/`}>Resümee lesen →</a>
            )}
          </li>
        ))}
      </ol>
    </section>
  ))}
</Basis>

<style>
  h2 {
    border-bottom: 1px solid var(--linie);
    padding-bottom: 0.25rem;
    margin-top: 2.5rem;
  }

  ol {
    padding-left: 1.5rem;
    margin: 1rem 0 0;
  }

  li {
    margin-bottom: 1.25rem;
    line-height: 1.5;
  }

  .autor {
    font-weight: 600;
  }

  .meta {
    color: var(--ink-soft);
  }

  .notiz {
    margin: 0.25rem 0 0;
    font-style: italic;
    color: var(--ink-soft);
    font-size: 0.9rem;
  }

  /* Link zum Resümee — dieselbe dezente Sprache wie „auch auf Substack".
     Eigene Zeile (block), damit er auch ohne Notiz nicht hinter dem Jahr klebt. */
  .resuemee-link {
    display: block;
    width: fit-content;
    margin-top: 0.35rem;
    font-family: var(--schrift-ui);
    font-size: 0.8rem;
    color: var(--grau);
    text-decoration: none;
    transition: color 0.15s ease, transform 0.35s var(--feder);
  }

  .resuemee-link:hover {
    color: var(--akzent);
    transform: translateX(4px);
  }
</style>
