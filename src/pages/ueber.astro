---
import Basis from '../layouts/Basis.astro';
import SokratesBueste from '../components/SokratesBueste.astro';
import { Content } from '../inhalte/ueber.md';
---

<Basis titel="Über — notitia">
  <SokratesBueste />
  <div class="inhalt">
    <Content />
  </div>
</Basis>

<style>
  .inhalt {
    animation: aufklaren 0.6s ease-out both;
  }

  /* Erste Überschrift (Seitentitel) etwas vom Bild abrücken */
  .inhalt :global(h1) {
    margin-top: 0;
  }
</style>
