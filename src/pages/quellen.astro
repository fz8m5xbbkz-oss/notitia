---
import Basis from '../layouts/Basis.astro';
import Vignette from '../components/Vignette.astro';
import { getCollection } from 'astro:content';
import { quellen, typReihenfolge, typLabel } from '../data/quellen.js';

// Quellen nach Typ gruppieren, in definierter Reihenfolge
const gruppen = typReihenfolge
  .map((typ) => ({
    typ,
    label: typLabel[typ],
    eintraege: quellen.filter((q) => q.typ === typ),
  }))
  .filter((g) => g.eintraege.length > 0);

// Slug → Essaytitel, um Quellen mit „erwähnt in" zu verknüpfen
const essays = await getCollection('essays');
const essayTitel = new Map(essays.map((e) => [e.id, e.data.title]));
---

<Basis
  titel="Quellen — annotanda"
  beschreibung="Bücher, Aufsätze und Primärtexte, auf die sich die Essays von annotanda stützen."
>
  <Vignette motiv="archiv" />
  <h1 data-reveal>Quellen</h1>

  <p data-reveal style="--reveal-delay: 80ms">
    Alle Texte, die in den Essays eine Rolle spielen — zur Orientierung
    für den, der tiefer lesen will.
  </p>

  {gruppen.length === 0 && (
    <p class="leer" data-reveal style="--reveal-delay: 160ms">
      Noch keine Einträge — das Verzeichnis wächst mit den Essays.
    </p>
  )}

  {gruppen.map(({ label, eintraege }) => (
    <section>
      <h2 data-reveal>{label}</h2>
      <ol>
        {eintraege.map((q, i) => (
          <li data-reveal style={`--reveal-delay: ${Math.min(i, 6) * 70}ms`}>
            <span class="autor">{q.autor ? `${q.autor}: ` : ''}</span>{q.url
              ? <a href={q.url} target="_blank" rel="noopener noreferrer"><em>{q.titel}</em></a>
              : <em>{q.titel}</em>
            }{q.untertitel && <span class="untertitel">. {q.untertitel}</span>}{q.jahr && <span class="meta">, {q.jahr}</span>}{q.verlag && <span class="meta">. {q.verlag}</span>}{q.notiz && <span class="notiz"> — {q.notiz}</span>}
            {q.essays && q.essays.some((s) => essayTitel.has(s)) && (
              <span class="erwaehnt">
                erwähnt in {q.essays.filter((s) => essayTitel.has(s)).map((s, i, arr) => (
                  <>
                    <a href={`/essays/${s}/`}>{essayTitel.get(s)}</a>{i < arr.length - 1 ? ', ' : ''}
                  </>
                ))}
              </span>
            )}
          </li>
        ))}
      </ol>
    </section>
  ))}
</Basis>

<style>
  h2 {
    border-bottom: 1px solid var(--linie);
    padding-bottom: 0.25rem;
    margin-top: 2.5rem;
  }

  ol {
    padding-left: 1.5rem;
    margin: 1rem 0 0;
  }

  li {
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }

  .autor {
    font-weight: 600;
  }

  .meta {
    color: var(--ink-soft);
  }

  .notiz {
    font-style: italic;
    color: var(--ink-soft);
    font-size: 0.9rem;
  }

  /* Querverweis auf den Essay, in dem die Quelle vorkommt */
  .erwaehnt {
    display: block;
    margin-top: 0.2rem;
    font-family: var(--schrift-ui);
    font-size: 0.8rem;
    color: var(--grau);
  }

  .erwaehnt a {
    color: var(--grau);
    text-decoration: underline;
    text-decoration-color: var(--linie);
  }

  .erwaehnt a:hover {
    color: var(--akzent);
  }

  .leer {
    color: var(--ink-soft);
    font-style: italic;
  }
</style>
