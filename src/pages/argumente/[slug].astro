---
import Basis from '../../layouts/Basis.astro';
import { argumente } from '../../data/argumente.js';

export function getStaticPaths() {
  return argumente.map((a) => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const eintrag = argumente.find((a) => a.slug === slug);
---

<Basis
  titel={`Argumente: ${eintrag.titel} — annotanda`}
  beschreibung={`Argumentationsstruktur des Essays „${eintrag.titel}"`}
>
  <p class="zurueck"><a href="/argumente/">← Alle Argument-Karten</a></p>

  <h1>{eintrag.titel}</h1>
  <p class="hinweis">Argumentationsstruktur des Essays</p>

  <div class="diagramm-wrapper">
    <pre class="mermaid">{eintrag.diagramm.trim()}</pre>
  </div>

  <p class="essay-link">
    <a href={`/essays/${eintrag.slug}/`}>Essay lesen →</a>
  </p>
</Basis>

<!-- Mermaid von CDN, kein npm install. is:inline hält den CDN-Import von Vite
     fern; gezeichnet wird über astro:page-load — sonst läuft das Skript bei
     View-Transition-Navigation nicht und das Diagramm bliebe leer. -->
<script is:inline type="module">
  import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';

  function zeichneMermaid() {
    const knoten = document.querySelectorAll('.mermaid');
    if (!knoten.length) return;

    // Farben aus den CSS-Variablen lesen, damit das Diagramm im Dark Mode lesbar bleibt
    const stil = getComputedStyle(document.documentElement);
    mermaid.initialize({
      startOnLoad: false,
      theme: 'base',
      themeVariables: {
        background: stil.getPropertyValue('--paper').trim(),
        primaryColor: stil.getPropertyValue('--paper').trim(),
        primaryBorderColor: stil.getPropertyValue('--akzent').trim(),
        primaryTextColor: stil.getPropertyValue('--ink').trim(),
        lineColor: stil.getPropertyValue('--akzent').trim(),
        edgeLabelBackground: stil.getPropertyValue('--paper').trim(),
        fontFamily: '-apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif',
        fontSize: '14px',
      },
    });

    // Quelltext sichern und zurücksetzen, damit auch ein erneutes Zeichnen
    // (z. B. nach Farbschema-Wechsel) sauber neu rendert
    knoten.forEach((n) => {
      if (!n.dataset.quelle) n.dataset.quelle = n.textContent;
      n.removeAttribute('data-processed');
      n.innerHTML = n.dataset.quelle;
    });

    mermaid.run({ nodes: Array.from(knoten) });
  }

  // Erstes Laden direkt ...
  zeichneMermaid();

  // ... und bei jeder weiteren Navigation neu zeichnen. Die Listener nur einmal
  // binden — document überlebt die ClientRouter-Seitenwechsel.
  if (!window.__mermaidGebunden) {
    window.__mermaidGebunden = true;
    document.addEventListener('astro:page-load', zeichneMermaid);
    // Farbschema-Wechsel: mit neuen Farben neu zeichnen, ohne Reload
    document.addEventListener('click', (e) => {
      if (e.target.closest('.schema-knopf')) setTimeout(zeichneMermaid, 180);
    });
  }
</script>

<style>
  .zurueck {
    font-family: var(--schrift-ui);
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }

  .hinweis {
    font-family: var(--schrift-ui);
    font-size: 0.9rem;
    color: var(--ink-soft);
    margin-top: -0.5rem;
  }

  .diagramm-wrapper {
    margin: 2rem 0;
    overflow-x: auto;
  }

  .mermaid {
    background: transparent;
    font-family: var(--schrift-ui);
  }

  .essay-link {
    margin-top: 2rem;
    font-family: var(--schrift-ui);
    font-size: 0.95rem;
  }
</style>
