---
import Basis from '../../layouts/Basis.astro';
import Vignette from '../../components/Vignette.astro';
import { argumente } from '../../data/argumente.js';
---

<Basis
  titel="Argumente — notitia"
  beschreibung="Argumentationsstrukturen der Essays — als Baumdiagramm."
>
  <Vignette motiv="baum" />
  <h1 data-reveal>Argumente</h1>

  <p data-reveal style="--reveal-delay: 80ms">
    Die Argumentationsstruktur jedes Essays — für den, der nicht nur lesen,
    sondern nachvollziehen will.
  </p>

  <ul>
    {argumente.map((a, i) => (
      <li data-reveal style={`--reveal-delay: ${160 + Math.min(i, 8) * 70}ms`}>
        <a href={`/argumente/${a.slug}/`}>{a.titel}</a>
      </li>
    ))}
  </ul>
</Basis>

<style>
  ul {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
  }

  li {
    border-top: 1px solid var(--linie);
    padding: 0.75rem 0;
  }

  li:last-child {
    border-bottom: 1px solid var(--linie);
  }

  a {
    font-size: 1.1rem;
  }
</style>
