---
import Basis from '../../layouts/Basis.astro';
import felderDaten from '../../data/felder.json';

const { felder } = felderDaten;
---

<Basis titel="Felder — magnolia">
  <h1>Felder</h1>
  <p class="einleitung">
    Fünf Felder, jeweils acht Themengebiete, jeweils fünf Unterthemen.
    Was hier steht, ist im Aufbau.
  </p>

  {felder.map((feld) => (
    <section class="feld">
      <h2><a href={`/felder/${feld.slug}`}>{feld.name}</a></h2>
      {feld.themengebiete.length === 0 ? (
        <p class="leer">Noch keine Themengebiete.</p>
      ) : (
        <ul class="themengebiete">
          {feld.themengebiete.map((tg) => (
            <li>
              <a class="tg-name" href={`/felder/${feld.slug}/${tg.slug}`}>{tg.name}</a>
              {tg.unterthemen.length > 0 && (
                <ul class="unterthemen">
                  {tg.unterthemen.map((ut) => (
                    <li>
                      <a href={`/felder/${feld.slug}/${tg.slug}/${ut.slug}`}>{ut.name}</a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ul>
      )}
    </section>
  ))}
</Basis>

<style>
  .einleitung {
    color: var(--grau);
    margin-bottom: 2.5rem;
  }

  .feld {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--linie);
  }

  .feld:last-child {
    border-bottom: none;
  }

  .feld h2 {
    margin-top: 0;
  }

  .feld h2 a {
    color: var(--ink);
    text-decoration: none;
  }

  .feld h2 a:hover {
    color: var(--akzent);
  }

  .themengebiete {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .themengebiete > li {
    margin-bottom: 1rem;
  }

  .tg-name {
    font-weight: 600;
    color: var(--ink);
    text-decoration: none;
  }

  .tg-name:hover {
    text-decoration: underline;
    text-decoration-color: var(--linie);
    text-underline-offset: 0.2em;
  }

  .unterthemen {
    list-style: none;
    padding-left: 1rem;
    margin: 0.25rem 0 0;
    color: var(--grau);
    font-size: 0.95rem;
  }

  .unterthemen li {
    padding: 0.15rem 0;
  }

  .unterthemen a {
    color: var(--grau);
    text-decoration: none;
  }

  .unterthemen a:hover {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--linie);
    text-underline-offset: 0.2em;
  }

  .leer {
    color: var(--grau);
    font-style: italic;
    margin: 0;
  }
</style>
