---
// Trailing Slash: die Seite wird mit trailingSlash 'always' gebaut —
// Links ohne Slash kosten sonst bei jedem Klick einen Redirect
const links = [
  { href: '/essays/', text: 'Essays' },
  { href: '/argumente/', text: 'Argumente' },
  { href: '/lektuere/', text: 'Lektüre' },
  { href: '/quellen/', text: 'Quellen' },
  { href: '/ueber/', text: 'Über' },
];

const wordmark = 'notitia'.split('');
---

<header>
  <a href="/" class="wordmark" aria-label="notitia — Startseite">
    {wordmark.map((buchstabe, i) => (
      <span aria-hidden="true" style={`--i: ${i}`}>{buchstabe}</span>
    ))}
  </a>
  <nav>
    {links.map(({ href, text }) => <a href={href}>{text}</a>)}
    <button class="schema-knopf" aria-label="Farbschema wechseln">
      <svg class="mond" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
      </svg>
      <svg class="sonne" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="4" />
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
      </svg>
    </button>
  </nav>
</header>

<script>
  // Manuelle Wahl überschreibt die System-Präferenz und bleibt gespeichert
  function wechsle() {
    const dunkel = document.documentElement.dataset.farbschema === 'dunkel';
    if (dunkel) {
      delete document.documentElement.dataset.farbschema;
      localStorage.setItem('farbschema', 'hell');
    } else {
      document.documentElement.dataset.farbschema = 'dunkel';
      localStorage.setItem('farbschema', 'dunkel');
    }
  }

  function schemaWechsel(knopf: Element) {
    const ruhig = matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (ruhig || !document.startViewTransition) {
      wechsle();
      return;
    }

    // Zirkulärer Wipe: das neue Farbschema breitet sich vom Knopf aus über die Seite aus
    const r = knopf.getBoundingClientRect();
    const x = r.left + r.width / 2;
    const y = r.top + r.height / 2;
    const radius = Math.hypot(
      Math.max(x, innerWidth - x),
      Math.max(y, innerHeight - y)
    );

    document.documentElement.classList.add('schema-wechsel');
    const uebergang = document.startViewTransition(wechsle);
    uebergang.ready.then(() => {
      document.documentElement.animate(
        {
          clipPath: [
            `circle(0px at ${x}px ${y}px)`,
            `circle(${radius}px at ${x}px ${y}px)`,
          ],
        },
        {
          duration: 450,
          easing: 'ease-in-out',
          pseudoElement: '::view-transition-new(root)',
        }
      );
    });
    uebergang.finished.finally(() =>
      document.documentElement.classList.remove('schema-wechsel')
    );
  }

  // Delegation auf document: überlebt die ClientRouter-Seitenwechsel,
  // weil document persistiert — der Knopf selbst wird beim Swap getauscht
  document.addEventListener('click', (e) => {
    const knopf = (e.target as Element).closest('.schema-knopf');
    if (knopf) schemaWechsel(knopf);
  });
</script>

<style>
  header {
    max-width: var(--max-breite);
    margin: 0 auto;
    padding: 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-bottom: 1px solid var(--linie);
    flex-wrap: wrap;
    gap: 1rem;
  }

  .wordmark {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  /* Buchstaben-Welle: jeder Buchstabe hebt gestaffelt ab und fächert leicht auf */
  .wordmark span {
    display: inline-block;
    transition:
      transform 0.4s var(--feder) calc(var(--i) * 30ms),
      color 0.25s ease calc(var(--i) * 30ms);
  }

  .wordmark:hover span {
    transform: translateY(-5px) rotate(calc((var(--i) - 3) * 2deg));
    color: var(--akzent);
  }

  nav {
    display: flex;
    gap: 1.25rem;
    font-family: var(--schrift-ui);
    font-size: 0.95rem;
  }

  nav a {
    display: inline-block;
    color: var(--grau);
    text-decoration: none;
    position: relative;
    transition:
      color 0.15s ease,
      transform 0.35s var(--feder);
  }

  nav a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -3px;
    width: 100%;
    height: 1px;
    background: var(--akzent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.2s ease;
  }

  nav a:hover {
    color: var(--ink);
    transform: translateY(-2px);
  }

  nav a:hover::after {
    transform: scaleX(1);
  }

  @media (prefers-reduced-motion: reduce) {
    nav a,
    nav a::after,
    .wordmark span {
      transition: none;
    }
  }

  .schema-knopf {
    position: relative;
    width: 24px;
    height: 24px;
    padding: 0;
    border: none;
    background: none;
    color: var(--grau);
    cursor: pointer;
    align-self: center;
    transition: transform 0.4s var(--feder), color 0.2s ease;
  }

  .schema-knopf:hover {
    color: var(--ink);
    transform: rotate(15deg) scale(1.15);
  }

  .schema-knopf:active {
    transform: scale(0.85);
  }

  .schema-knopf svg {
    position: absolute;
    inset: 4px;
    transition: opacity 0.2s ease, transform 0.3s ease;
  }

  .schema-knopf .sonne {
    opacity: 0;
    transform: rotate(-45deg) scale(0.8);
  }

  :global(html[data-farbschema='dunkel']) .schema-knopf .mond {
    opacity: 0;
    transform: rotate(45deg) scale(0.8);
  }

  :global(html[data-farbschema='dunkel']) .schema-knopf .sonne {
    opacity: 1;
    transform: none;
  }
</style>
